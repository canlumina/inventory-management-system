# Runtime environment: development or production.
ENVIRONMENT=development

# PostgreSQL used by docker-compose.yml.
POSTGRES_DB=inventory_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-postgres-password

# Backend security. Replace before setting ENVIRONMENT=production.
SECRET_KEY=dev-secret-key-change-before-production
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Development bootstrap account.
CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123

# Frontend dev-server proxy target inside Docker Compose.
VITE_API_PROXY_TARGET=http://backend:8000
